{
  "name": "gutu-lib-admin-widgets",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/admin-widgets build",
    "typecheck": "bun run --cwd framework/libraries/admin-widgets typecheck",
    "lint": "bun run --cwd framework/libraries/admin-widgets lint",
    "test": "bun run --cwd framework/libraries/admin-widgets test",
    "test:unit": "bun run --cwd framework/libraries/admin-widgets test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
